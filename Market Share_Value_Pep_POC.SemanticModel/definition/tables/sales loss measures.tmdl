	measure Category_Size = ```
			
			VAR TotalUnits = CALCULATE(
			    SUM(Book1[revenue]),
			    REMOVEFILTERS(Book1[product],Book1[Brand_type_]) // Optional, ensures it's at category aggregation
			)
			VAR AvgMRP = CALCULATE(
			    AVERAGE(Book1[mrp]),
			    REMOVEFILTERS(Book1[product],Book1[Brand_type_]) // Optional
			)
			RETURN
			    TotalUnits * AvgMRP
			
			```
		formatString: "₹"\ #,0;-"₹"\ #,0;"₹"\ #,0
		lineageTag: b8b288e0-046a-480e-9816-dfb4e71f9176

		annotation PBI_FormatHint = {"currencyCulture":"brx-IN"}

	measure PSG_output_final =
			
			VAR last_7_day_summarize =
			 CALCULATE(AVERAGEX(Book1,Book1[inventory_change] * Book1[mrp]),Book1[Brand_type_] = "Own",DATESINPERIOD(Book1[backend_inserted_date],MAX(Book1[backend_inserted_date]),-7,DAY))
			
			VAR latest_ = CALCULATE(AVERAGEX(Book1,Book1[inventory_change] * Book1[mrp]),Book1[Brand_type_] = "Own",
			        Book1[backend_inserted_date] = MAX(Book1[backend_inserted_date]))
			
			VAR Final_=  latest_ - last_7_day_summarize
			
			VAR final_output= IF(Final_ > 0,Final_,BLANK())
			
			RETURN
			final_output
		lineageTag: 32ca60ea-15a2-4b1a-b183-4c3ec86fc521

		annotation PBI_FormatHint = {"isGeneralNumber":true}

