table 'sales loss measures'
	lineageTag: c1194b0c-2bcb-4434-80c4-6bba1941e937

	measure Avg_Units_7Day =
			
			AVERAGEX(
			    DATESINPERIOD(
			        'Calendar'[Date],
			        MAX('Calendar'[Date]),
			        -30,
			        DAY
			    ),
			    CALCULATE(SUM(Book1[inventory_change]))
			)
		lineageTag: d3bb299e-b7bf-4948-8bad-7534fa025fe1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Sales_Loss_Units = ```
			
			VAR LastDate1 = CALCULATE(MAX('Calendar'[Date]), ALL('Calendar'))
			VAR AvgUnits = 
			    AVERAGEX(
			        DATESINPERIOD(
			            'Calendar'[Date],
			            LastDate1,
			            -1,
			            DAY
			        ),
			        CALCULATE(SUM(Book1[inventory_change]))
			    )
			VAR UnitsYesterday =
			    CALCULATE(
			        SUM(Book1[inventory_change]),
			        'Calendar'[Date] = LastDate1
			    )
			VAR LossUnits = AvgUnits - UnitsYesterday
			RETURN
			    IF(LossUnits > 0, LossUnits, 0)
			```
		lineageTag: 2c4b79ed-147f-4fc6-b082-f708d20da753

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure PSL =
			
			VAR LossUnits = [Sales_Loss_Units]
			VAR ASP = CALCULATE(AVERAGE(Book1[asp]))  // Or whatever field is ASP
			RETURN
			    -1 * LossUnits * ASP
		formatString: "₹"\ #,0.00;-"₹"\ #,0.00;"₹"\ #,0.00
		lineageTag: d4397ebd-b4a2-47fd-b1f3-6c045fcf2138

		annotation PBI_FormatHint = {"currencyCulture":"brx-IN"}

	measure ASP_Own =
			
			CALCULATE(
			    AVERAGE(Book1[asp]),
			    Book1[Brand_type_] = "Own"
			)
		lineageTag: 0f59ecd7-319d-4f25-ac68-a9855db52340

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure PSL_output_final =
			
			VAR last_7_day_summarize =
			 CALCULATE(AVERAGE(Book1[revenue]),Book1[Brand_type_] = "Own",DATESINPERIOD(Book1[backend_inserted_date],MAX(Book1[backend_inserted_date]),-7,DAY))
			
			VAR latest_ = CALCULATE(AVERAGE(Book1[revenue]),Book1[Brand_type_] = "Own",
			        Book1[backend_inserted_date] = MAX(Book1[backend_inserted_date]))
			
			VAR Final_=  latest_ - last_7_day_summarize
			
			VAR final_output= IF(Final_ < 0,Final_,BLANK())
			
			RETURN
			Final_
			
