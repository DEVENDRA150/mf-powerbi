	measure Measure
		lineageTag: 6c1d4f5a-d70e-4e9a-9ac8-94e704e3b5e4

		annotation 43dbc3e8-3a1c-4b6f-9923-b49ff7d6691c = True

	measure Sales_Gain_Units =
			
			VAR LastDate1 = CALCULATE(MAX(Book1[backend_inserted_date]), ALL(Book1))
			VAR AvgUnits =
			    AVERAGEX(
			        DATESINPERIOD(
			            'Calendar'[Date],
			            LastDate1,
			            -7,
			            DAY
			        ),
			        CALCULATE(SUMX(Book1,Book1[inventory_change]*Book1[mrp]))
			    )
			VAR UnitsYesterday =
			    CALCULATE(
			        SUMX(Book1,Book1[inventory_change]*Book1[mrp]),
			        Book1[backend_inserted_date] = LastDate1
			    )
			VAR GainUnits = UnitsYesterday - AvgUnits
			RETURN
			    IF(GainUnits > 0, GainUnits, BLANK())
			
			
			
			
			
			
			
			
			
			
			
			
			
