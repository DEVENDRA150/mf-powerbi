	measure Inventory_DoD_Change =
			
			VAR UnitsToday =
			    SUM(Book1[inventory_change])
			VAR UnitsPrev =
			    CALCULATE(
			        SUM(Book1[inventory_change]),
			        DATEADD('Calendar'[Date], -1, DAY)
			    )
			RETURN
			    UnitsToday - UnitsPrev
		formatString: 0
		lineageTag: bbca5302-88e8-4ffd-9c05-2fb890224311

