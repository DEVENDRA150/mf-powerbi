	measure 'Comaparsion Share_comp' = [date2_custom_market_share_comp]-[date1_custom_market_share_comp]
		lineageTag: 495de2cc-50ff-485d-b73c-fccd89ae3cf3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Change_Color_customer_Comparision_share_comp = ```
			
			VAR Changevalue = [date1_custom_market_share_comp] - [date2_custom_market_share_comp] 
			
			RETURN
			    SWITCH (
			        TRUE(),
			        Changevalue < 0, "#9DF1B7",   -- Red  
			        Changevalue > 0, "#FFC3C1",   -- Green
			        "#808080"                       -- Grey (no change)
			    )
			```
		lineageTag: 2a1c3bd9-4630-4bf6-ae90-fda2fccc30e1

