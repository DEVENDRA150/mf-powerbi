	measure date1_custom_market_share_comp =
			
			CALCULATE([market share],TREATAS(VALUES(Calendar1[Date]),Book1[backend_inserted_date]),
			    REMOVEFILTERS(Calendar2[Date]))
		lineageTag: f0cf53e3-f654-4730-8edb-409690a84b00

