	measure date2_custom_market_share_comp =
			
			CALCULATE([market share],TREATAS(VALUES(Calendar2[Date]),Book1[backend_inserted_date]),
			    REMOVEFILTERS(Calendar1[Date]))
		lineageTag: 32bcc49d-8ce5-409e-b324-2e0b83579465

