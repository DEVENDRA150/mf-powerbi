			  //  CALCULATE([Share %], 'Calendar'[Date] = MaxDate)
			//VAR SharePrev =
			  //  CALCULATE([Share %], 'Calendar'[Date] = PrevDate)
			//RETURN
			  //  ShareToday
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 59793d80-e6c5-4d35-8e45-1e8b676e8924

	measure DOD_Change_Direction =
			
			IF([DOD_Change_share_%] < 0, "Negative", "Positive or Zero")
		lineageTag: e1fb2ed2-e56c-4762-8bec-81aeaf631acc

	measure Market_Share_%_OEM_Group = ```
			
			VAR CurrentOEM = SELECTEDVALUE(Book1[Oem_code])
			VAR CurrDate = MAX('Calendar'[Date])
			RETURN
			DIVIDE(
			    CALCULATE(
			        SUM(Book1[inventory_change]),
			        Book1[Brand_type_] = "Own",
			        TREATAS({CurrentOEM}, Book1[Oem_code_group_]),  // Forces OEM context, ignores SKU
			        Book1[backend_inserted_date] = CurrDate
			    ),
			    CALCULATE(
			        SUM(Book1[inventory_change]),
			        REMOVEFILTERS(Book1[Brand_type_]),
			        TREATAS({CurrentOEM}, Book1[Oem_code_Group_]),
			        Book1[backend_inserted_date] = CurrDate
			    )
			)
			
			```
		lineageTag: ceb774f6-d88b-49a7-8de6-634a9587008b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure sharechangeoveravg = [Share%_Latest] - marketshare[Avg_Share %]
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: c09bd06b-2933-401c-91cb-4edadb67ad8e

