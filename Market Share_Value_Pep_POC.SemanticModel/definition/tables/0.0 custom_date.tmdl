			//          Book1[backend_inserted_date] >= date1_start_date  && Book1[backend_inserted_date] <= date1_end_date)
			//     )
			//     RETURN num
			
			
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 3d2d0138-21f4-423e-bf85-c94f128ec31b

	measure date2 = ```
			
			CALCULATE([own_market_share],TREATAS(VALUES(Calendar2[Date]),Book1[backend_inserted_date]),
			    REMOVEFILTERS(Calendar1[Date]))
			
			
			// VAR date2_start_date = MIN ( Calendar2[Date] )
			// VAR date2_end_date   = MAX ( Calendar2[Date] )
			
			// VAR last_days_sale =
			//       CALCULATE (
			//         [own_market_share],
			//          FILTER(Book1,
			//          Book1[backend_inserted_date]>=date2_start_date 
			//          && 
			//          Book1[backend_inserted_date]<=date2_end_date ))
			// RETURN
			//     last_days_sale
			
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 83909534-3011-47ad-9343-c18afcaf0fa4

	measure own_market_share =
			
			var own_revenue  = CALCULATE(SUM(Book1[revenue]),Book1[Brand_type_]="Own")
			var total_revenue  = CALCULATE(SUM(Book1[revenue]))
			
			RETURN DIVIDE(own_revenue,total_revenue)
		lineageTag: 13552dec-5f4d-42bc-9b60-9619664c6a49

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Comaparsion Share' = [date2]-[date1]
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 1faa1dcd-9334-4eb6-bc5c-5ee7d9efebdc

