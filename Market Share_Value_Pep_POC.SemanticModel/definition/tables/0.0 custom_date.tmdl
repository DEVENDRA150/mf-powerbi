table '0.0 custom_date'
	lineageTag: 645fa83e-960b-4993-8b1e-fe2465cf5a6c

	measure date1 = ```
			
			CALCULATE([own_market_share],TREATAS(VALUES(Calendar1[Date]),Book1[backend_inserted_date]),
			    REMOVEFILTERS(Calendar2[Date]))
			
			
			
			// VAR date1_start_date = MIN ( Calendar1[Date] )
			// VAR date1_end_date   = MAX ( Calendar1[Date] )
